@page
@model MovieMatchApp.Pages.AddMovieModel

<h2>Add a Movie</h2>

<br />

<form method="post">
    <div>
        <label>Title:</label>
        <input asp-for="Movie.Title" />
    </div>

    <br />

    <div>
        <label>Genre:</label>
        <input asp-for="Movie.Genre" />
    </div>

    <br />

    <div>
        <label>Description:</label>
        <input asp-for="Movie.Description" />
    </div>

    <br />

    <div>
        <label>Release Year:</label>
        <input asp-for="Movie.ReleaseYear" type="number" />
    </div>

    <br />

    <div>
        <label>Runtime (minutes):</label>
        <input asp-for="Movie.Runtime" type="number" />
    </div>
    
    <br />

    <button type="submit">Add Movie</button>

      
</form>