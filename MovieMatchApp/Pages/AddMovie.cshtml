@page
@model MovieMatchApp.Pages.AddMovieModel

<h2>Add a Movie</h2>

<br />

<!-- sends to OnPost() -->

<form method="post">

    <!-- for movie title -->
    <div>
        <label>Title:</label>
        <input asp-for="Movie.Title" />
    </div>

    <br />

    <!-- for director -->
    <div> 
        <label>Director:</label>
        <input asp-for="Movie.Director" />
    </div>

     <br />

    <!-- for genre -->
    <div>
        <label>Genre:</label>
        <input asp-for="Movie.Genre" />
    </div>

    <br />

    <!-- Will use this info for quiz -->
    <div>
        <label>Mood:</label>
        <input asp-for="Movie.Mood" />
    </div>

     <br />

    <!-- for description -->
    <div>
        <label>Description:</label>
        <input asp-for="Movie.Description" />
    </div>

    <br />

    <!-- for release year -->
    <div>
        <label>Release Year:</label>
        <input asp-for="Movie.ReleaseYear" type="number" />
    </div>

    <br />
     
     <!-- runtime in minutes -->
    <div>
        <label>Runtime (minutes):</label>
        <input asp-for="Movie.Runtime" type="number" />
    </div>
    
    <br />
    
     <!-- Submit button -->
    <button type="submit">Add Movie</button>

      
</form>