@page
@model MovieMatchApp.Pages.WatchlistModel

<h2>My Watchlist</h2>

<div style="text-align:center;">
    <a href="/AddMovie">Add Movie</a>
    <a href="/RandomMovie">Surprise Me</a>
    <a href="/MoodQuiz">Take Quiz</a>
</div>

<div class="movie-grid">
    @foreach (var movie in Model.Movies)
    {
        <div class="movie-card">
            <h3>@movie.Title (@movie.ReleaseYear)</h3>

            <p class="movie-meta">
                @movie.Genre | @movie.Director
            </p>

            <p>@movie.Description</p>

            <p><strong>@movie.Runtime min</strong> • Mood: @movie.Mood</p>

            <div class="actions">
                <form method="post" asp-page-handler="Delete" style="display:inline;">
                    <input type="hidden" name="id" value="@movie.MovieID" />
                    <button type="submit">Delete</button>
                </form>

                <a href="/EditMovie?id=@movie.MovieID">Edit</a>
            </div>
        </div>
    }
</div>

@if (!Model.Movies.Any())
{
    <p style="text-align:center;">No movies yet. Add some!</p>
}
